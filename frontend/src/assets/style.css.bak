/* ========== Reset & Base ========== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --bg: #0f172a;
  --bg-card: #1e293b;
  --bg-light: #334155;
  --primary: #3b82f6;
  --primary-hover: #60a5fa;
  --secondary: #10b981;
  --text: #f8fafc;
  --text-dim: #94a3b8;
  --success: #22c55e;
  --warning: #f59e0b;
  --danger: #ef4444;
  --radius: 12px;
  --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

body {
  font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

#app {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ========== Header ========== */
.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 24px;
  background: var(--bg-card);
  border-bottom: 2px solid var(--primary);
  gap: 20px;
}

.header-left h1 {
  cursor: pointer;
  font-size: 1.4rem;
  color: var(--primary);
  margin: 0;
  white-space: nowrap;
}

.header-nav {
  display: flex;
  gap: 8px;
  flex: 1;
  justify-content: center;
}

.nav-item {
  padding: 10px 22px;
  border-radius: 24px;
  color: var(--text-dim);
  text-decoration: none;
  font-weight: 600;
  font-size: 0.95rem;
  transition: all 0.2s;
  border: 1px solid transparent;
}

.nav-item:hover {
  color: var(--text);
  background: var(--bg-light);
  border-color: var(--bg-light);
}

.nav-active {
  color: var(--primary) !important;
  background: rgba(59, 130, 246, 0.15);
  border-color: var(--primary);
}

.nav-right {
  margin-left: auto;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.user-info {
  color: var(--text-dim);
  font-size: 0.9rem;
}

/* ========== Buttons ========== */
.btn {
  padding: 10px 20px;
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  font-size: 0.95rem;
  font-weight: 600;
  transition: all 0.2s;
  color: white;
  background: var(--bg-light);
}

.btn:hover:not(:disabled) { opacity: 0.85; }

.btn:disabled {
  cursor: not-allowed;
  opacity: 0.6;
}

.btn-primary { background: var(--primary); }
.btn-primary:hover:not(:disabled) { background: var(--primary-hover); }

.btn-secondary { background: var(--secondary); }
.btn-secondary:hover:not(:disabled) { opacity: 0.8; }

.btn-warn { background: var(--warning); color: #000; }

.btn-sm { padding: 6px 12px; font-size: 0.85rem; }

.btn-ready { background: var(--success); }

.btn-target {
  background: var(--bg-light);
  border: 2px solid var(--text-dim);
  padding: 12px 16px;
  font-size: 1rem;
}

.btn-target:hover:not(:disabled) {
  border-color: var(--primary);
  background: var(--primary);
}

.btn-vote:hover:not(:disabled) {
  border-color: var(--danger);
  background: var(--danger);
}

/* ========== Forms ========== */
.form-group {
  margin-bottom: 16px;
}

.form-group label {
  display: block;
  margin-bottom: 6px;
  font-size: 0.9rem;
  color: var(--text-dim);
}

.form-group input {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--bg-light);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--text);
  font-size: 1rem;
  outline: none;
  transition: border-color 0.2s;
}

.form-group input:focus {
  border-color: var(--primary);
}

/* ========== Login Page ========== */
.login-page {
  display: flex;
  justify-content: center;
  align-items: center;
  flex: 1;
  padding: 40px 20px;
}

.login-card {
  background: var(--bg-card);
  padding: 40px;
  border-radius: 12px;
  width: 100%;
  max-width: 400px;
  text-align: center;
}

.login-card h2 { font-size: 2rem; margin-bottom: 8px; }
.login-card .subtitle { color: var(--text-dim); margin-bottom: 24px; }

.error { color: var(--danger); font-size: 0.85rem; margin-bottom: 12px; }

.toggle { margin-top: 20px; font-size: 0.9rem; color: var(--text-dim); }
.toggle a { color: var(--primary); text-decoration: none; }

/* ========== Lobby ========== */
.lobby {
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 24px;
  flex: 1;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}

/* Join bar */
.join-bar {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 16px 20px;
  box-shadow: var(--shadow);
}

.join-bar .join-row {
  display: flex;
  gap: 12px;
}

.join-bar .code-input {
  flex: 1;
  padding: 12px 16px;
  border: 1px solid var(--bg-light);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--text);
  font-size: 1.1rem;
  text-transform: uppercase;
  letter-spacing: 3px;
  text-align: center;
  outline: none;
}

.join-bar .code-input:focus { border-color: var(--primary); }

/* Zones grid */
.zones-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

@media (max-width: 900px) {
  .zones-grid {
    grid-template-columns: 1fr;
  }
}

/* Zone card */
.zone-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  transition: transform 0.2s;
}

.zone-card:hover {
  transform: translateY(-2px);
}

.zone-header {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 20px;
  color: white;
}

.zone-header.zone-6 {
  background: linear-gradient(135deg, #2563eb, #3b82f6);
}

.zone-header.zone-8 {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
}

.zone-header.zone-12 {
  background: linear-gradient(135deg, #dc2626, #ef4444);
}

.zone-icon {
  font-size: 2.2rem;
  flex-shrink: 0;
}

.zone-info h2 {
  font-size: 1.2rem;
  margin: 0 0 4px;
  color: white;
}

.zone-desc {
  font-size: 0.78rem;
  opacity: 0.85;
  margin: 0;
  line-height: 1.4;
}

.zone-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex: 1;
}

.btn-create-zone {
  width: 100%;
  padding: 12px;
  border: 2px dashed var(--bg-light);
  border-radius: var(--radius);
  background: transparent;
  color: var(--text-dim);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-create-zone:hover:not(:disabled) {
  border-color: var(--primary);
  color: var(--primary);
  background: rgba(59, 130, 246, 0.05);
}

.btn-create-zone:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.zone-rooms {
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
  min-height: 60px;
  max-height: 300px;
  overflow-y: auto;
}

.zone-empty {
  color: var(--text-dim);
  text-align: center;
  padding: 20px;
  font-size: 0.85rem;
}

/* Room items (used in zones and general) */
.room-list { display: flex; flex-direction: column; gap: 8px; }

.room-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: var(--bg);
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.2s;
}

.room-item:hover { background: var(--bg-light); }

.room-code { font-size: 1.3rem; font-weight: 700; letter-spacing: 3px; color: var(--primary); }
.room-info { display: flex; gap: 16px; font-size: 0.85rem; color: var(--text-dim); }

.empty { color: var(--text-dim); text-align: center; padding: 20px; font-size: 0.9rem; }

/* ========== Room Page ========== */
.room-page {
  display: flex;
  flex: 1;
  min-height: 100vh;
  background: var(--bg);
}

.room-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24px;
  gap: 20px;
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}

.room-title {
  display: flex;
  align-items: center;
  gap: 12px;
}

.room-title h2 {
  font-size: 1.3rem;
  letter-spacing: 3px;
  color: var(--primary);
  margin: 0;
}

.room-mode-badge {
  padding: 4px 12px;
  background: rgba(59, 130, 246, 0.15);
  border: 1px solid var(--primary);
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--primary);
}

.room-header-info {
  font-size: 0.9rem;
  color: var(--text-dim);
}

/* ========== Seat Grid ========== */
.seat-grid-wrapper {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.seat-grid-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-dim);
}

.seat-grid {
  display: grid;
  gap: 14px;
  flex: 1;
  place-items: center;
}

/* Layouts by player count */
.seat-grid-6 {
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(2, 1fr);
}

.seat-grid-8 {
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(2, 1fr);
}

.seat-grid-12 {
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(3, 1fr);
}

/* Seat card */
.seat-card {
  width: 100%;
  max-width: 180px;
  aspect-ratio: 1;
  border-radius: 16px;
  border: 2px dashed var(--bg-light);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: all 0.2s;
  position: relative;
  background: rgba(0, 0, 0, 0.15);
  cursor: default;
}

/* Occupied seat */
.seat-card.seat-occupied {
  border-style: solid;
  border-color: var(--bg-light);
  background: rgba(0, 0, 0, 0.2);
  cursor: default;
}

.seat-card.seat-me {
  border-color: var(--primary);
  border-width: 3px;
  background: rgba(59, 130, 246, 0.1);
  box-shadow: 0 0 12px rgba(59, 130, 246, 0.2);
}

.seat-card.seat-host {
  border-color: #f59e0b;
}

.seat-card.seat-ready {
  border-color: var(--success);
  background: rgba(34, 197, 94, 0.08);
}

.seat-card.seat-ai {
  border-color: #a855f7;
}

/* Seat content */
.seat-number {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-dim);
}

.seat-number-occupied {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--primary);
  background: rgba(59, 130, 246, 0.15);
  padding: 2px 8px;
  border-radius: 10px;
}

.seat-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-hover));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.seat-avatar.ai-avatar {
  background: linear-gradient(135deg, #7c3aed, #a855f7);
}

.seat-name {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text);
}

.seat-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  justify-content: center;
}

.seat-badges .badge {
  font-size: 0.7rem;
  padding: 2px 7px;
  border-radius: 4px;
}

.badge-host {
  background: rgba(245, 158, 11, 0.2);
  color: #f59e0b;
}

.badge-ai {
  background: rgba(168, 85, 247, 0.2);
  color: #c084fc;
}

.badge-ready {
  background: rgba(34, 197, 94, 0.2);
  color: #22c55e;
}

.badge-not-ready {
  background: rgba(148, 163, 184, 0.15);
  color: var(--text-dim);
}

.btn-remove-seat {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 22px;
  height: 22px;
  border: none;
  border-radius: 50%;
  background: #dc2626;
  color: white;
  font-size: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
  z-index: 2;
}

.btn-remove-seat:hover {
  background: #b91c1c;
}

/* Room actions update */
.room-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 16px 20px;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  flex-wrap: wrap;
}

.actions-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.actions-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.room-sidebar {
  width: 340px;
  flex-shrink: 0;
  padding: 24px 12px;
  display: flex;
  flex-direction: column;
}

.room-sidebar .game-section {
  flex: 1;
}

.room-actions {
  display: flex;
  justify-content: center;
  gap: 12px;
  padding: 20px;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  flex-wrap: wrap;
}

.add-ai-container {
  display: flex;
  gap: 10px;
  align-items: center;
}

.agent-select {
  padding: 10px 14px;
  border: 1px solid var(--bg-light);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--text);
  font-size: 0.9rem;
  min-width: 180px;
  cursor: pointer;
}

.agent-select option {
  background: var(--bg-card);
  color: var(--text);
}

/* ========== Player Grid ========== */
.player-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 12px;
}

.player-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 16px 12px;
  text-align: center;
  border: 2px solid transparent;
  transition: all 0.2s;
}

.player-card.alive { border-color: var(--success); }
.player-card.dead { border-color: #555; opacity: 0.5; }
.player-card.me { border-color: var(--primary); }
.player-card.host { border-color: gold; }

.player-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  font-weight: 700;
  margin: 0 auto 8px;
}

.player-card.dead .player-avatar { background: #555; }

.player-name { font-size: 0.9rem; font-weight: 600; }

.player-badges {
  display: flex;
  justify-content: center;
  gap: 4px;
  margin-top: 6px;
  flex-wrap: wrap;
}

.badge { font-size: 0.75rem; padding: 2px 6px; border-radius: 4px; }

.seat-num-badge {
  position: absolute;
  top: 6px;
  left: 6px;
  padding: 2px 8px;
  background: var(--primary);
  color: white;
  border-radius: 10px;
  font-size: 0.7rem;
  font-weight: 700;
  z-index: 2;
}

.player-card.dead .seat-num-badge {
  background: #555;
}

.btn-remove-ai {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 20px;
  height: 20px;
  border: none;
  border-radius: 50%;
  background: #dc2626;
  color: #fff;
  font-size: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.btn-remove-ai:hover {
  background: #b91c1c;
}

.player-card {
  position: relative;
}

/* ========== Game Page ========== */
.game-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 0;
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 24px;
  background: var(--bg-card);
  border-bottom: 1px solid var(--bg-light);
  gap: 20px;
}

.game-header-left {
  flex-shrink: 0;
}

.game-header-center {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 24px;
}

.game-header-right {
  flex-shrink: 0;
}

.phase-indicator {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 24px;
  font-weight: 700;
  font-size: 1rem;
  box-shadow: var(--shadow);
}

.phase-indicator.waiting { 
  background: var(--bg-light); 
  color: var(--text-dim);
}
.phase-indicator.night { 
  background: linear-gradient(135deg, #312e81, #1e1b4b); 
  color: #a5b4fc;
}
.phase-indicator.day { 
  background: linear-gradient(135deg, #f59e0b, #d97706); 
  color: #fff;
}
.phase-indicator.vote { 
  background: linear-gradient(135deg, #ef4444, #dc2626); 
  color: #fff;
}
.phase-indicator.end { 
  background: linear-gradient(135deg, #10b981, #059669); 
  color: #fff;
}

.phase-icon {
  font-size: 1.2rem;
}

.night-number {
  font-size: 0.85rem;
  opacity: 0.8;
}

.my-role {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--bg);
  border-radius: 24px;
  border: 2px solid var(--primary);
  font-weight: 600;
}

.role-emoji {
  font-size: 1.2rem;
}

.role-name {
  color: var(--primary);
}

.game-message {
  padding: 10px 16px;
  background: rgba(245, 158, 11, 0.1);
  border: 1px solid rgba(245, 158, 11, 0.3);
  border-radius: var(--radius);
  font-size: 0.95rem;
  color: var(--warning);
  font-weight: 600;
}

.game-main {
  display: flex;
  flex: 1;
  padding: 20px;
  gap: 20px;
  overflow: hidden;
  min-height: 0;
  max-height: calc(100vh - 60px);
}

.game-left-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20px;
  height: 500px;
}

.game-right-panel {
  width: 340px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  height: 500px;
}

.game-section {
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  min-height: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: rgba(0, 0, 0, 0.1);
  border-bottom: 1px solid var(--bg-light);
  flex-shrink: 0;
}

.section-header h3 {
  font-size: 1rem;
  margin: 0;
  color: var(--text);
}

.section-badge {
  padding: 4px 10px;
  background: var(--bg-light);
  border-radius: 12px;
  font-size: 0.8rem;
  color: var(--text-dim);
}

.player-section {
  flex-shrink: 0;
  height: 180px;
  display: flex;
  flex-direction: column;
}

.player-section .section-header {
  background: rgba(59, 130, 246, 0.1);
  border-bottom-color: rgba(59, 130, 246, 0.2);
}

.player-section .player-grid-wrapper {
  flex: 1;
  overflow-y: auto;
}

.action-section {
  flex: 1;
  min-height: 280px;
  display: flex;
  flex-direction: column;
}

.action-section > div {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
}

.chat-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

/* ========== Countdown ========== */
.countdown-bar {
  flex: 1;
  height: 24px;
  background: var(--bg-card);
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  min-width: 120px;
  max-width: 300px;
}

.countdown-fill {
  height: 100%;
  border-radius: 12px;
  transition: width 1s linear;
}

.countdown-fill.safe { background: var(--success); }
.countdown-fill.warning { background: var(--warning); }
.countdown-fill.danger { background: var(--danger); }

.countdown-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 0.8rem;
  font-weight: 700;
}

/* ========== Night Panel ========== */
.night-panel {
  background: var(--bg-card);
  padding: 20px;
  border-radius: var(--radius);
  border-left: 4px solid #2c3e80;
}

.night-waiting p { color: var(--text-dim); }

.action-message {
  margin-bottom: 12px;
  font-weight: 600;
}

.target-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.witch-options {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.witch-mode-toggle {
  display: flex;
  gap: 8px;
}

.btn-mode {
  flex: 1;
  background: var(--bg-light);
  border: 2px solid var(--text-dim);
}

.btn-mode.active {
  border-color: var(--primary);
  background: var(--primary);
}

.btn-mode:disabled {
  opacity: 0.4;
}

.btn-target.selected {
  border-color: var(--primary);
  background: var(--primary);
  box-shadow: 0 0 12px var(--primary);
}

.action-confirm {
  margin-top: 16px;
  display: flex;
  gap: 8px;
  justify-content: center;
}

.btn-danger { background: var(--danger); }
.btn-danger:hover:not(:disabled) { background: #c0392b; }

.action-done { color: var(--success); font-weight: 600; }

/* ========== Day Panel ========== */
.day-panel {
  background: var(--bg-card);
  padding: 20px;
  border-radius: var(--radius);
  border-left: 4px solid #d4a017;
}

.day-message { margin-bottom: 12px; }
.day-message p { font-size: 1.1rem; font-weight: 600; color: var(--warning); }

.day-actions { display: flex; flex-direction: column; gap: 8px; align-items: flex-start; }
.day-dead p { color: var(--text-dim); font-style: italic; }

/* ========== Vote Panel ========== */
.vote-panel {
  background: var(--bg-card);
  padding: 20px;
  border-radius: var(--radius);
  border-left: 4px solid var(--danger);
}

.vote-title { margin-bottom: 12px; font-weight: 600; }

.vote-done {
  text-align: center;
  padding: 20px;
}

.vote-message {
  font-size: 18px;
  font-weight: bold;
  color: #4ade80;
  margin-bottom: 10px;
}

.vote-target {
  font-size: 16px;
  color: #fca5a5;
}

.vote-target strong {
  color: #ef4444;
  font-size: 18px;
}

/* ========== Overlays ========== */
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.85);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 100;
  padding: 20px;
}

.role-reveal-card, .result-card {
  background: var(--bg-card);
  padding: 40px;
  border-radius: 16px;
  text-align: center;
  max-width: 500px;
  width: 100%;
  animation: fadeIn 0.3s;
}

@keyframes fadeIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }

.role-icon, .result-icon { font-size: 4rem; margin-bottom: 12px; }

.role-reveal-card h1 { font-size: 2rem; color: var(--primary); margin: 8px 0; }
.role-reveal-card h2 { font-size: 1.1rem; color: var(--text-dim); }
.role-desc { color: var(--text-dim); margin: 12px 0 20px; font-size: 0.95rem; }

.result-card h1 { font-size: 1.8rem; color: var(--primary); margin: 8px 0; }
.result-msg { color: var(--text-dim); margin-bottom: 8px; }
.result-duration { color: var(--text-dim); font-size: 0.9rem; margin-bottom: 20px; }

.result-players {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 20px;
  text-align: left;
  max-height: 300px;
  overflow-y: auto;
}

.result-player {
  display: grid;
  grid-template-columns: 1fr 80px 60px 40px;
  align-items: center;
  padding: 8px 12px;
  background: var(--bg);
  border-radius: 4px;
  font-size: 0.9rem;
}

.result-player.winner { background: rgba(46, 204, 113, 0.1); }

.rp-name { font-weight: 600; }
.rp-role { color: var(--text-dim); }
.rp-status { color: var(--text-dim); }

.result-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  margin-top: 20px;
}

/* ========== Chat ========== */
.chat-box {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 300px;
  max-height: calc(100% - 48px);
  background: transparent;
}

.chat-box h4 {
  display: none;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.chat-messages::-webkit-scrollbar {
  width: 8px;
}

.chat-messages::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 4px;
}

.chat-messages::-webkit-scrollbar-thumb {
  background: var(--bg-light);
  border-radius: 4px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.chat-messages::-webkit-scrollbar-thumb:hover {
  background: #475569;
}

.chat-messages {
  scrollbar-width: thin;
  scrollbar-color: var(--bg-light) rgba(0, 0, 0, 0.2);
}

.chat-empty { 
  color: var(--text-dim); 
  font-size: 0.85rem; 
  text-align: center; 
  padding: 40px 20px; 
}

.chat-msg { 
  font-size: 0.9rem; 
  line-height: 1.5; 
  padding: 8px 12px;
  border-radius: var(--radius);
  background: rgba(0, 0, 0, 0.1);
}

.chat-msg.system {
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.2);
  text-align: center;
}

.chat-user { 
  color: var(--primary); 
  font-weight: 600; 
  margin-right: 8px; 
  font-size: 0.85rem;
}

.chat-text { 
  color: var(--text); 
  white-space: pre-wrap; 
  word-break: break-word; 
}

.chat-input {
  display: flex;
  gap: 8px;
  padding: 10px;
  border-top: 1px solid var(--bg-light);
}

.chat-input input {
  flex: 1;
  padding: 10px 14px;
  border: 1px solid var(--bg-light);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--text);
  font-size: 0.9rem;
  outline: none;
  transition: border-color 0.2s;
}

.chat-input input:focus { 
  border-color: var(--primary); 
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

/* ========== Game Sidebar ========== */
.game-sidebar {
  display: flex;
  flex-direction: column;
}

.game-sidebar .chat-box {
  flex: 1;
}

/* ========== Responsive ========== */
@media (max-width: 768px) {
  .room-page {
    flex-direction: column;
  }

  .room-sidebar {
    width: 100%;
    padding: 12px 24px 24px;
  }

  .game-main {
    flex-direction: column;
  }

  .game-right-panel {
    width: 100%;
  }

  .game-header {
    flex-wrap: wrap;
    padding: 12px 16px;
  }

  .game-header-center {
    order: 3;
    width: 100%;
    justify-content: flex-start;
  }

  .player-grid {
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
  }

  .room-header {
    flex-direction: column;
    gap: 12px;
  }

  .room-actions {
    flex-direction: column;
  }
}

/* ========== AI Workshop ========== */
.workshop-page {
  min-height: 100vh;
  padding: 20px;
}

.workshop-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 20px;
}

.workshop-header h1 {
  font-size: 1.5rem;
  color: var(--primary);
}

.btn-back, .btn-create {
  padding: 10px 20px;
  border-radius: var(--radius);
  border: none;
  cursor: pointer;
  font-weight: 600;
}

.btn-back {
  background: var(--bg-light);
  color: var(--text);
}

.btn-back:hover {
  background: #475569;
}

.btn-create {
  background: var(--primary);
  color: white;
}

.btn-create:hover {
  background: var(--primary-hover);
}

.workshop-content {
  display: flex;
  gap: 20px;
  height: calc(100vh - 140px);
}

.agent-list {
  width: 350px;
  flex-shrink: 0;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 20px;
  overflow-y: auto;
}

.agent-list h2 {
  font-size: 1.1rem;
  margin-bottom: 16px;
  color: var(--text);
}

.empty-state {
  text-align: center;
  padding: 40px 20px;
  color: var(--text-dim);
}

.agent-card {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px;
  background: rgba(0, 0, 0, 0.1);
  border-radius: var(--radius);
  margin-bottom: 10px;
  cursor: pointer;
  transition: all 0.2s;
  border: 2px solid transparent;
}

.agent-card:hover {
  background: rgba(0, 0, 0, 0.2);
}

.agent-card.active {
  border-color: var(--primary);
  background: rgba(59, 130, 246, 0.1);
}

.agent-avatar {
  font-size: 2rem;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-light);
  border-radius: 50%;
}

.agent-info {
  flex: 1;
}

.agent-info h3 {
  font-size: 0.95rem;
  margin-bottom: 4px;
}

.agent-personality-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.tag {
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 600;
}

.tag.aggressive { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
.tag.cautious { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }
.tag.cunning { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
.tag.honest { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
.tag.talkative { background: rgba(168, 85, 247, 0.2); color: #a855f7; }

.agent-actions {
  display: flex;
  gap: 6px;
}

.btn-edit, .btn-delete {
  padding: 6px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  background: transparent;
  font-size: 1rem;
}

.btn-edit:hover {
  background: rgba(59, 130, 246, 0.2);
}

.btn-delete:hover {
  background: rgba(239, 68, 68, 0.2);
}

.agent-detail {
  flex: 1;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 20px;
  overflow-y: auto;
}

.agent-detail h2 {
  font-size: 1.1rem;
  margin-bottom: 20px;
  color: var(--text);
}

.detail-section {
  margin-bottom: 24px;
}

.detail-section label {
  display: block;
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  gap: 12px;
  padding: 10px;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 8px;
  margin-bottom: 8px;
}

.info-label {
  color: var(--text-dim);
  font-size: 0.9rem;
}

.info-value {
  color: var(--text);
  font-weight: 600;
}

.personality-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
}

.personality-item {
  background: rgba(0, 0, 0, 0.1);
  padding: 14px;
  border-radius: 8px;
}

.item-label {
  display: block;
  font-size: 0.85rem;
  color: var(--text);
  margin-bottom: 8px;
}

.progress-bar {
  height: 8px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 4px;
}

.progress-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s;
}

.progress-fill.aggressive { background: linear-gradient(90deg, #ef4444, #f97316); }
.progress-fill.cautious { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
.progress-fill.cunning { background: linear-gradient(90deg, #f59e0b, #eab308); }
.progress-fill.honest { background: linear-gradient(90deg, #22c55e, #4ade80); }
.progress-fill.talkative { background: linear-gradient(90deg, #a855f7, #c084fc); }

.item-value {
  font-size: 0.85rem;
  color: var(--text-dim);
}

.strategy-grid, .language-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
}

.strategy-item, .language-item {
  background: rgba(0, 0, 0, 0.1);
  padding: 12px;
  border-radius: 8px;
}

.strategy-label, .language-label {
  display: block;
  font-size: 0.85rem;
  color: var(--text-dim);
  margin-bottom: 4px;
}

.strategy-value, .language-value {
  color: var(--text);
  font-size: 0.9rem;
}

.detail-actions {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.detail-actions .btn-edit, .detail-actions .btn-delete {
  padding: 10px 20px;
  font-size: 0.9rem;
}

.detail-actions .btn-edit {
  background: var(--primary);
  color: white;
}

.detail-actions .btn-delete {
  background: var(--danger);
  color: white;
}

/* Modal */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: var(--bg-card);
  border-radius: var(--radius);
  padding: 24px;
  width: 90%;
  max-width: 600px;
  max-height: 90vh;
  overflow-y: auto;
}

.modal-content h2 {
  font-size: 1.2rem;
  margin-bottom: 20px;
}

.form-group {
  margin-bottom: 20px;
}

.form-group label {
  display: block;
  font-size: 0.9rem;
  color: var(--text);
  margin-bottom: 8px;
}

.form-group input {
  width: 100%;
  padding: 10px;
  border: 1px solid var(--bg-light);
  border-radius: 8px;
  background: var(--bg);
  color: var(--text);
  font-size: 0.9rem;
}

.avatar-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.avatar-option {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  background: var(--bg);
  border-radius: 8px;
  cursor: pointer;
  border: 2px solid transparent;
}

.avatar-option.selected {
  border-color: var(--primary);
  background: rgba(59, 130, 246, 0.1);
}

.personality-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.slider-item {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.slider-label {
  font-size: 0.85rem;
  color: var(--text);
}

.slider-item input[type="range"] {
  width: 100%;
  height: 6px;
  accent-color: var(--primary);
}

.style-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.style-btn {
  padding: 8px 16px;
  border: 2px solid var(--bg-light);
  border-radius: 8px;
  background: transparent;
  color: var(--text);
  cursor: pointer;
  font-size: 0.85rem;
}

.style-btn.active {
  border-color: var(--primary);
  background: rgba(59, 130, 246, 0.1);
}

.strategy-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.strategy-select {
  display: flex;
  align-items: center;
  gap: 12px;
}

.strategy-select span {
  font-size: 0.85rem;
  color: var(--text);
}

.strategy-select select {
  flex: 1;
  padding: 8px;
  border: 1px solid var(--bg-light);
  border-radius: 8px;
  background: var(--bg);
  color: var(--text);
}

.language-form {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.language-form input {
  width: 100%;
  padding: 10px;
  border: 1px solid var(--bg-light);
  border-radius: 8px;
  background: var(--bg);
  color: var(--text);
  font-size: 0.9rem;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 24px;
}

.btn-cancel {
  padding: 10px 20px;
  border: 1px solid var(--bg-light);
  border-radius: 8px;
  background: transparent;
  color: var(--text);
  cursor: pointer;
}

.btn-save {
  padding: 10px 20px;
  border: none;
  border-radius: 8px;
  background: var(--primary);
  color: white;
  cursor: pointer;
}

.btn-save:hover {
  background: var(--primary-hover);
}

/* ========== Profile Page ========== */
.profile-page {
  max-width: 600px;
  margin: 0 auto;
  padding: 20px;
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px;
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 20px;
}

.profile-header h1 {
  font-size: 1.5rem;
  color: var(--primary);
  margin: 0;
}

.header-spacer {
  width: 100px;
}

.profile-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.profile-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 30px;
  display: flex;
  align-items: center;
  gap: 24px;
}

.profile-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-hover));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 2.5rem;
  color: white;
  font-weight: 700;
}

.profile-info h2 {
  font-size: 1.4rem;
  margin: 0 0 12px;
  color: var(--text);
}

.profile-stats {
  display: flex;
  gap: 24px;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  font-size: 0.8rem;
  color: var(--text-dim);
}

.edit-card {
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 30px;
}

.edit-card h3 {
  font-size: 1.1rem;
  margin: 0 0 24px;
  color: var(--text);
}

.form-input {
  width: 100%;
  padding: 12px 14px;
  border: 1px solid var(--bg-light);
  border-radius: var(--radius);
  background: var(--bg);
  color: var(--text);
  font-size: 0.95rem;
  box-sizing: border-box;
}

.form-input:focus {
  outline: none;
  border-color: var(--primary);
}

.form-hint {
  display: block;
  font-size: 0.75rem;
  color: var(--text-dim);
  margin-top: 6px;
}

.form-message {
  padding: 12px;
  border-radius: var(--radius);
  margin-bottom: 16px;
  font-size: 0.9rem;
  text-align: center;
}

.form-message.success {
  background: rgba(34, 197, 94, 0.1);
  color: var(--success);
}

.form-message.error {
  background: rgba(239, 68, 68, 0.1);
  color: var(--danger);
}

.btn-danger {
  background: var(--danger);
  color: white;
  margin-top: 12px;
}

.btn-danger:hover {
  background: #dc2626;
}
